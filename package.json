{
  "name": "mcp-hub",
  "version": "0.1.0",
  "private": true,
  "description": "MCP Hub — 一个域名托管多个 MCP 服务，让 AI Agent 直接调用你的工具",
  "author": {
    "name": "IceyWu",
    "url": "https://github.com/IceyWu"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IceyWu/mcp-hub"
  },
  "license": "MIT",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "build:mcp": "tsc -p mcp-servers/tencent-docs/tsconfig.json",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "dev": "eve dev",
    "start": "eve start",
    "typecheck": "tsc",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm --filter tencent-docs-mcp run build && changeset publish"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^3.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vercel/connect": "0.3.0",
    "ai": "^7.0.9",
    "eve": "^0.17.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "24.x",
    "just-bash": "^3.0.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24.x"
  }
}
