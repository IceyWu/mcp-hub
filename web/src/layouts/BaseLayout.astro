---
import { t } from "../i18n/translations";
import HomePage from "../components/HomePage.astro";

const locale = (Astro.currentLocale ?? "zh-CN") as "zh-CN" | "en";
const dict = t(locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>MCP Hub</title>
  </head>
  <body>
    <div class="container">
      <HomePage t={dict} locale={locale} />
    </div>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family:
      "Inter",
      "SF Pro Display",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    color: #1a1a1a;
    background: #fafafa;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 40px 0 36px;
  }

  .logo {
    display: flex;
    align-items: center;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .logo:hover {
    opacity: 0.65;
  }

  .role {
    font-size: 13px;
    font-weight: 400;
    color: #aaa;
    letter-spacing: -0.01em;
    flex: 1;
    line-height: 1;
  }

  .lang-switch {
    font-size: 12px;
    font-weight: 500;
    color: #aaa;
    padding: 2px 8px;
    border: 1px solid #ddd;
    border-radius: 5px;
    line-height: 1;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
  }

  .lang-switch:hover {
    background: #f3f3f3;
    color: #555;
    border-color: #bbb;
  }

  .main {
    padding-top: 8px;
  }

  .title {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.18;
    letter-spacing: -0.03em;
    margin-bottom: 18px;
    color: #0d0d0d;
  }

  .desc {
    font-size: 15px;
    line-height: 1.55;
    color: #666;
    margin-bottom: 12px;
    max-width: 520px;
  }

  .usage {
    font-size: 14px;
    line-height: 1.55;
    color: #777;
    margin-bottom: 28px;
    max-width: 540px;
  }

  .usage code {
    font-family: "JetBrains Mono", "SF Mono", "Fira Code", monospace;
    font-size: 12px;
    font-weight: 500;
    background: #eee;
    padding: 2px 5px;
    border-radius: 4px;
    color: #444;
  }

  .code-wrap {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 56px;
  }

  .code-block {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex: 1;
    background: #1a1a1a;
    color: #e0e0e0;
    font-family: "JetBrains Mono", "SF Mono", "Fira Code", monospace;
    font-size: 12px;
    padding: 14px 16px;
    border-radius: 8px;
    overflow: hidden;
    line-height: 1.6;
  }

  .code-block pre {
    margin: 0;
    overflow: auto;
    flex: 1;
  }

  .code-block code {
    white-space: pre;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: #888;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    flex-shrink: 0;
    transition:
      color 0.15s,
      background 0.15s;
  }

  .copy-btn:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .copy-btn.copied {
    color: #4ade80;
  }

  .gh-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 500;
    color: #666;
    padding: 9px 14px;
    border: 1px solid #d4d4d4;
    border-radius: 8px;
    white-space: nowrap;
    margin-top: 1px;
    transition:
      background 0.15s,
      border-color 0.15s;
  }

  .gh-link:hover {
    background: #f3f3f3;
    border-color: #bbb;
  }

  .gh-link svg {
    opacity: 0.6;
  }

  .section {
    margin-bottom: 48px;
  }

  .section-title {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #0d0d0d;
    margin-bottom: 16px;
  }

  .cards {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    overflow: hidden;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 14px 18px;
    background: #fff;
    transition: background 0.15s;
  }

  .card:hover {
    background: #f8f8f8;
  }

  .card + .card {
    border-top: 1px solid #eee;
  }

  .card-title {
    font-size: 14px;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 12px;
    color: #999;
    line-height: 1.45;
  }

  .card-detail {
    font-size: 11px;
    color: #bbb;
    line-height: 1.4;
    margin-top: 2px;
  }

  .how-desc {
    font-size: 14px;
    color: #777;
    line-height: 1.55;
    max-width: 520px;
  }

  .iceberg {
    margin-bottom: 48px;
  }

  .iceberg-desc {
    font-size: 14px;
    color: #777;
    line-height: 1.55;
    margin-bottom: 18px;
    max-width: 520px;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 500;
    color: #1a1a1a;
    padding: 9px 18px;
    border: 1px solid #d4d4d4;
    border-radius: 8px;
    transition:
      background 0.15s,
      border-color 0.15s;
  }

  .cta:hover {
    background: #f3f3f3;
    border-color: #bbb;
  }

  .cta svg {
    opacity: 0.5;
    transition: transform 0.15s;
  }

  .cta:hover svg {
    transform: translateX(2px);
  }

  .footer {
    padding: 28px 0 44px;
    font-size: 12px;
    color: #bbb;
    border-top: 1px solid #eee;
  }

  @media (max-width: 640px) {
    .header {
      padding: 32px 0 24px;
    }

    .title {
      font-size: 26px;
    }

    .code-wrap {
      flex-direction: column;
      align-items: stretch;
    }

    .gh-link {
      justify-content: center;
    }
  }
</style>
